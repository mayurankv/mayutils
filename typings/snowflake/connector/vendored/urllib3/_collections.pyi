import typing
from enum import Enum
from threading import RLock
from typing import Protocol, Self

if typing.TYPE_CHECKING:
    class HasGettableStringKeys(Protocol):
        def keys(self) -> typing.Iterator[str]: ...
        def __getitem__(self, key: str) -> str: ...

__all__ = ["HTTPHeaderDict", "RecentlyUsedContainer"]
_KT = typing.TypeVar("_KT")
_VT = typing.TypeVar("_VT")
_DT = typing.TypeVar("_DT")
type ValidHTTPHeaderSource = HTTPHeaderDict | typing.Mapping[str, str] | typing.Iterable[tuple[str, str]] | HasGettableStringKeys

class _Sentinel(Enum):
    not_passed = ...

def ensure_can_construct_http_header_dict(potential: object) -> ValidHTTPHeaderSource | None: ...

class RecentlyUsedContainer[KT, VT](typing.MutableMapping[KT, VT]):
    _container: typing.OrderedDict[_KT, _VT]
    _maxsize: int
    dispose_func: typing.Callable[[_VT], None] | None
    lock: RLock
    def __init__(self, maxsize: int = ..., dispose_func: typing.Callable[[_VT], None] | None = ...) -> None: ...
    def __getitem__(self, key: _KT) -> _VT: ...
    def __setitem__(self, key: _KT, value: _VT) -> None: ...
    def __delitem__(self, key: _KT) -> None: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> typing.NoReturn: ...
    def clear(self) -> None: ...
    def keys(self) -> set[_KT]: ...

class HTTPHeaderDictItemView(set[tuple[str, str]]):
    _headers: HTTPHeaderDict
    def __init__(self, headers: HTTPHeaderDict) -> None: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> typing.Iterator[tuple[str, str]]: ...
    def __contains__(self, item: object) -> bool: ...

class HTTPHeaderDict(typing.MutableMapping[str, str]):
    _container: typing.MutableMapping[str, list[str]]
    def __init__(self, headers: ValidHTTPHeaderSource | None = ..., **kwargs: str) -> None: ...
    def __setitem__(self, key: str, val: str) -> None: ...
    def __getitem__(self, key: str) -> str: ...
    def __delitem__(self, key: str) -> None: ...
    def __contains__(self, key: object) -> bool: ...
    def setdefault(self, key: str, default: str = ...) -> str: ...
    def __eq__(self, other: object) -> bool: ...
    def __ne__(self, other: object) -> bool: ...
    def __len__(self) -> int: ...
    def __iter__(self) -> typing.Iterator[str]: ...
    def discard(self, key: str) -> None: ...
    def add(self, key: str, val: str, *, combine: bool = ...) -> None: ...
    def extend(self, *args: ValidHTTPHeaderSource, **kwargs: str) -> None: ...
    @typing.overload
    def getlist(self, key: str) -> list[str]: ...
    @typing.overload
    def getlist(self, key: str, default: _DT) -> list[str] | _DT: ...
    def getlist(self, key: str, default: _Sentinel | _DT = ...) -> list[str] | _DT: ...

    getheaders = ...
    getallmatchingheaders = ...
    iget = ...
    get_all = ...
    def copy(self) -> Self: ...
    def iteritems(self) -> typing.Iterator[tuple[str, str]]: ...
    def itermerged(self) -> typing.Iterator[tuple[str, str]]: ...
    def items(self) -> HTTPHeaderDictItemView: ...
    def __ior__(self, other: object) -> typing.Self: ...
    def __or__(self, other: object) -> Self: ...
    def __ror__(self, other: object) -> Self: ...
