import typing
from enum import Enum
from typing import Final

if typing.TYPE_CHECKING: ...

class _TYPE_DEFAULT(Enum):
    token = ...

_DEFAULT_TIMEOUT: Final[_TYPE_DEFAULT] = ...
type _TYPE_TIMEOUT = float | _TYPE_DEFAULT | None

class Timeout:
    DEFAULT_TIMEOUT: _TYPE_TIMEOUT = ...
    def __init__(self, total: _TYPE_TIMEOUT = ..., connect: _TYPE_TIMEOUT = ..., read: _TYPE_TIMEOUT = ...) -> None: ...

    __str__ = ...
    @staticmethod
    def resolve_default_timeout(timeout: _TYPE_TIMEOUT) -> float | None: ...
    @classmethod
    def from_float(cls, timeout: _TYPE_TIMEOUT) -> Timeout: ...
    def clone(self) -> Timeout: ...
    def start_connect(self) -> float: ...
    def get_connect_duration(self) -> float: ...
    @property
    def connect_timeout(self) -> _TYPE_TIMEOUT: ...
    @property
    def read_timeout(self) -> float | None: ...
