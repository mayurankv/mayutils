import typing

type _TYPE_FIELD_VALUE = str | bytes
type _TYPE_FIELD_VALUE_TUPLE = _TYPE_FIELD_VALUE | tuple[str, _TYPE_FIELD_VALUE] | tuple[str, _TYPE_FIELD_VALUE, str]

def guess_content_type(filename: str | None, default: str = ...) -> str: ...
def format_header_param_rfc2231(name: str, value: _TYPE_FIELD_VALUE) -> str: ...
def format_multipart_header_param(name: str, value: _TYPE_FIELD_VALUE) -> str: ...
def format_header_param_html5(name: str, value: _TYPE_FIELD_VALUE) -> str: ...
def format_header_param(name: str, value: _TYPE_FIELD_VALUE) -> str: ...

class RequestField:
    def __init__(
        self,
        name: str,
        data: _TYPE_FIELD_VALUE,
        filename: str | None = ...,
        headers: typing.Mapping[str, str] | None = ...,
        header_formatter: typing.Callable[[str, _TYPE_FIELD_VALUE], str] | None = ...,
    ) -> None: ...
    @classmethod
    def from_tuples(
        cls, fieldname: str, value: _TYPE_FIELD_VALUE_TUPLE, header_formatter: typing.Callable[[str, _TYPE_FIELD_VALUE], str] | None = ...
    ) -> RequestField: ...
    def render_headers(self) -> str: ...
    def make_multipart(
        self, content_disposition: str | None = ..., content_type: str | None = ..., content_location: str | None = ...
    ) -> None: ...
