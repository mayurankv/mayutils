class WrappedSocket:
    def __init__(self, connection: OpenSSL.SSL.Connection, socket: socket_cls, suppress_ragged_eofs: bool = ...) -> None: ...
    def fileno(self) -> int: ...
    def recv(self, *args: typing.Any, **kwargs: typing.Any) -> bytes: ...
    def recv_into(self, *args: typing.Any, **kwargs: typing.Any) -> int: ...
    def settimeout(self, timeout: float) -> None: ...
    def sendall(self, data: bytes) -> None: ...
    def shutdown(self, how: int) -> None: ...
    def close(self) -> None: ...
    def getpeercert(self, binary_form: bool = ...) -> dict[str, list[typing.Any]] | None: ...
    def version(self) -> str: ...
    def selected_alpn_protocol(self) -> str | None: ...

class PyOpenSSLContext:
    def __init__(self, protocol: int) -> None: ...
    @property
    def options(self) -> int: ...
    @options.setter
    def options(self, value: int) -> None: ...
    @property
    def verify_flags(self) -> int: ...
    @verify_flags.setter
    def verify_flags(self, value: int) -> None: ...
    @property
    def verify_mode(self) -> int: ...
    @verify_mode.setter
    def verify_mode(self, value: ssl.VerifyMode) -> None: ...
    def set_default_verify_paths(self) -> None: ...
    def set_ciphers(self, ciphers: bytes | str) -> None: ...
    def load_verify_locations(self, cafile: str | None = ..., capath: str | None = ..., cadata: bytes | None = ...) -> None: ...
    def load_cert_chain(self, certfile: str, keyfile: str | None = ..., password: str | None = ...) -> None: ...
    def set_alpn_protocols(self, protocols: list[bytes | str]) -> None: ...
    def wrap_socket(
        self,
        sock: socket_cls,
        server_side: bool = ...,
        do_handshake_on_connect: bool = ...,
        suppress_ragged_eofs: bool = ...,
        server_hostname: bytes | str | None = ...,
    ) -> WrappedSocket: ...
    @property
    def minimum_version(self) -> int: ...
    @minimum_version.setter
    def minimum_version(self, minimum_version: int) -> None: ...
    @property
    def maximum_version(self) -> int: ...
    @maximum_version.setter
    def maximum_version(self, maximum_version: int) -> None: ...
